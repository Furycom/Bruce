# === BRUCE .dockerignore (task [868]) ===
# Build context = mcp-stack/ root
# Whitelist approach: ignore everything, then allow what we need

# Ignore everything by default
*

# Allow only what the Dockerfile needs
!server.js
!shared/
!routes/
!mcp-gateway/package.json
!mcp-gateway/package-lock.json
!mcp-gateway/entrypoint.sh
!mcp-gateway/connectors.json
!mcp-gateway/Dockerfile

# Re-exclude nested junk in allowed dirs
**/*.bak*
**/*.backup*
**/*.log
**/.git
**/node_modules
