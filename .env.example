# BRUCE MCP-Stack — Environment Variables
# Copy this file to .env and fill in the values

# Supabase
SUPABASE_URL=http://192.168.2.146:8000/rest/v1
SUPABASE_KEY=               # JWT service_role key from Supabase

# Bruce Gateway Auth
BRUCE_AUTH_TOKEN=            # Bearer token for gateway API
BRUCE_TOKEN=                 # Alias (same value as BRUCE_AUTH_TOKEN)
GATEWAY_URL=http://192.168.2.230:4000

# LLM
BRUCE_LLM_API_KEY=           # API key for local LLM
BRUCE_LLM_MODEL=alpha
BRUCE_LITELLM_KEY=           # LiteLLM proxy key

# Langfuse (optional)
LANGFUSE_SECRET_KEY=         # Langfuse secret key
