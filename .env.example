# =============================================================================
# BRUCE MCP Gateway environment template
#
# Format:
#   - [REQUIRED] = should be set explicitly for production/useful deployments.
#   - [OPTIONAL] = has an application fallback default in code.
#
# Replace placeholder values before running in real environments.
# =============================================================================

# =============================================================================
# Core server
# =============================================================================
# [OPTIONAL] HTTP port for the gateway server.
PORT=4000

# =============================================================================
# Supabase / data services
# =============================================================================
# [REQUIRED] Supabase project URL used for database/vector operations.
SUPABASE_URL=https://your-project-id.supabase.co

# [REQUIRED] Supabase API key (service role recommended for server-side writes).
SUPABASE_KEY=your-supabase-key

# [OPTIONAL] Fallback PostgREST endpoint used if direct Supabase REST URL differs.
SUPABASE_REST_FALLBACK_URL=https://your-supabase-rest.example.com/rest/v1

# =============================================================================
# LLM and embedding backends
# =============================================================================
# [OPTIONAL] Embedding service base URL.
EMBEDDER_URL=http://localhost:8081

# [OPTIONAL] LiteLLM proxy base URL.
LITELLM_URL=http://localhost:4100

# [OPTIONAL] Local LLM endpoint (e.g., llama.cpp/OpenAI-compatible local server).
LOCAL_LLM_URL=http://localhost:8000

# [OPTIONAL] Internal vLLM URL reachable from Docker/internal network.
VLLM_INTERNAL_URL=http://localhost:4101

# [REQUIRED] Bruce LLM provider base URL when using direct provider calls.
BRUCE_LLM_API_BASE=https://api.example-llm.com/v1

# [REQUIRED] Default model name used by Bruce.
BRUCE_LLM_MODEL=example-model-name

# [REQUIRED] API key for the configured LLM provider.
BRUCE_LLM_API_KEY=your-llm-api-key

# [OPTIONAL] LiteLLM auth key/header value when routing through LiteLLM.
BRUCE_LITELLM_KEY=your-litellm-key

# [OPTIONAL] Maximum characters allowed per Bruce message.
BRUCE_MAX_MESSAGE_CHARS=8000

# [OPTIONAL] LLM request timeout in milliseconds.
BRUCE_LLM_TIMEOUT_MS=15000

# [OPTIONAL] Maximum concurrent Bruce LLM requests.
BRUCE_MAX_CONCURRENT=3

# [OPTIONAL] Default source label stored with Bruce operations.
BRUCE_SOURCE_DEFAULT=openwebui

# =============================================================================
# Bruce auth and fallback behavior
# =============================================================================
# [REQUIRED] Shared token validated by Bruce-protected routes.
BRUCE_AUTH_TOKEN=replace-with-a-strong-token

# [OPTIONAL] Local file path used to log fallback responses/errors.
BRUCE_FALLBACK_LOG_PATH=./bruce-fallback.log

# =============================================================================
# RAG route tuning (routes/rag.js)
# =============================================================================
# [OPTIONAL] Max query length accepted by RAG endpoint (characters).
BRUCE_RAG_MAX_Q_CHARS=4000

# [OPTIONAL] Timeout for embedding generation calls (milliseconds).
BRUCE_RAG_EMBED_TIMEOUT_MS=8000

# [OPTIONAL] Timeout for Supabase read/search operations in RAG (milliseconds).
BRUCE_RAG_SUPABASE_TIMEOUT_MS=8000

# [OPTIONAL] Rate-limit window for RAG endpoint (milliseconds).
BRUCE_RAG_RATE_WINDOW_MS=10000

# [OPTIONAL] Max requests allowed per rate-limit window for RAG endpoint.
BRUCE_RAG_RATE_MAX=30

# =============================================================================
# Internal/public service URLs
# =============================================================================
# [OPTIONAL] Internal validate service URL used for server-to-server calls.
VALIDATE_SERVICE_URL=http://localhost:4001

# [OPTIONAL] Public validate service URL used when external reachability is required.
VALIDATE_PUBLIC_URL=https://validate.example.com

# [OPTIONAL] Inbox runner ingestion endpoint URL.
INBOX_RUNNER_URL=http://localhost:4002/inbox/ingest

# [OPTIONAL] Browserless service URL for browser automation.
BROWSERLESS_URL=http://localhost:3000

# [OPTIONAL] MCP Playwright bridge URL.
MCP_PLAYWRIGHT_URL=http://localhost:5678

# [OPTIONAL] Publicly reachable base URL of this gateway.
GATEWAY_PUBLIC_URL=https://gateway.example.com

# [OPTIONAL] Loopback base URL used for local self-calls.
LOOPBACK_BASE_URL=http://127.0.0.1

# =============================================================================
# Filesystem paths
# =============================================================================
# [OPTIONAL] Root path to manual documents served/used by the gateway.
MANUAL_ROOT=/path/to/manual-docs
