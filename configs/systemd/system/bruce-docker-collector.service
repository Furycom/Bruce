[Unit]
Description=BRUCE Docker observed_snapshots collector (POST to PostgREST)
After=docker.service
Wants=docker.service

[Service]
Type=oneshot
User=furycom
Group=furycom
WorkingDirectory=/home/furycom
Environment=PYTHONUNBUFFERED=1
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/usr/bin/python3 /home/furycom/bruce_docker_post_observed_snapshot.py
